# route-optimizer-factory — worker configuration (Phase 4).
# Phase 1 (optimizer + parity) needs none of these; they document the queue
# worker's intended config so the contract is visible now. Copy to .env to use.

# --- Backend callback (POST /ro/progress) ---
# Base URL of team-dashboard-backend-v3 (the webhook is OUTSIDE /api/v3).
RO_BACKEND_URL=http://127.0.0.1:3000
# Shared secret sent as `Authorization: Bearer <secret>`; MUST match the backend's
# RO_WORKER_SECRET. See route-optimizer-decoupling-plan.md §7a.
RO_WORKER_SECRET=

# --- Queue (dbo.ro_jobs) ---
# SQL Server connection (same database as the backend / dbo.nm_queue).
RO_SQL_SERVER=
RO_SQL_DATABASE=
RO_SQL_USER=
RO_SQL_PASSWORD=

# --- Shared storage (EFS) ---
# Root that contains the `route_optimizer/` folder; mirrors the backend's EFS_PATH.
# The `route_optimizer` subdir is a fixed constant in code (not configurable), so
# the worker and backend always agree on the folder.
EFS_PATH=/mnt/efs

# --- Worker loop tuning ---
RO_WORKER_ID=ro-factory-local
RO_POLL_INTERVAL_SECONDS=5
RO_LEASE_SECONDS=300
RO_MAX_ATTEMPTS=3
